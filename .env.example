# =============================================================================
# ML Gen — Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# =============================================================================

# --- Splunk HEC Connection ---
SPLUNK_HEC_URL=https://your-splunk:8088
SPLUNK_HEC_TOKEN=your-hec-token-here
SPLUNK_INDEX=mlgen
SPLUNK_SOURCETYPE=_json
SSL_VERIFY=false

# --- Backfill ---
# On startup, the generator automatically backfills historical data for all
# entities (using normal behavior) to build a clean ML training baseline.
# After backfill completes, it transitions to continuous generation where
# each entity follows its assigned behavior (normal / lower / upper outlier).
BACKFILL_DAYS=90

# Interval in seconds between data points during backfill
BACKFILL_INTERVAL=60

# --- Entity Configuration ---
#
# Seasonal entities follow day-of-week and hour-of-day patterns
# (e.g. security logs, web traffic — higher during business hours)
NUM_NORMAL=5
NUM_LOWER_OUTLIER=1
NUM_UPPER_OUTLIER=1

# Flat entities have NO seasonality — steady, near-constant volumes
# (e.g. IT ops metrics collection, SNMP, performance monitoring)
NUM_FLAT_NORMAL=1
NUM_FLAT_LOWER_OUTLIER=1

# Behavior-change entities simulate progressive data onboarding:
# Volume ramps up over ~60 days, then shifts to a higher baseline for the
# last ~30 days. Useful for demoing ML model retraining / adaptation.
NUM_BEHAVIOR_CHANGE=1

# Variation percentage for outlier entities (applied as +/- to baseline)
VARIATION_PCT=75

# Anomaly cycling: outlier entities automatically alternate between anomaly
# and normal phases to simulate realistic incident lifecycles.
# Comma-separated list of possible durations in hours (one is picked randomly).
ANOMALY_DURATIONS=12,24,48
NORMAL_DURATIONS=48,72,96,168

# Entity names are picked from a built-in catalog of realistic Splunk data sources
# (e.g. security:linux_secure, cloud:aws:cloudtrail, network:pan:traffic).
# If you need more entities than the catalog has (20), extras use this prefix.
ENTITY_PREFIX=custom

# --- Generation Settings ---
# Interval in seconds between data points in continuous mode
GENERATION_INTERVAL=60

# HEC batch size (events are batched before sending)
HEC_BATCH_SIZE=1000

# Seasonality mode: curve (sine wave peaking at noon) or stdev (Gaussian peaking at 18h)
SEASONALITY_MODE=curve

# --- Instance & Control ---

# Instance ID: if set, this fixed value is used as instance_id for all events.
# If empty (default), a new UUID is generated each time the container starts.
# Useful when you want to keep the same instance_id across restarts.
INSTANCE_ID=

# Disable all anomalies: set to 1 to force ALL entities (including outliers
# and short-cycle) to normal behavior. No anomaly cycles will run.
# Useful for generating a clean baseline without any outliers.
# 0 = normal behavior (default), 1 = all anomalies disabled.
DISABLE_ALL_ANOMALIES=0

# --- Logging & Debug ---
LOG_LEVEL=INFO
DRY_RUN=false
