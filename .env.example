# =============================================================================
# ML Gen — Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# =============================================================================

# --- Splunk HEC Connection ---
SPLUNK_HEC_URL=https://your-splunk:8088
SPLUNK_HEC_TOKEN=your-hec-token-here
SPLUNK_INDEX=mlgen
SPLUNK_SOURCETYPE=_json
SSL_VERIFY=false

# --- Mode ---
# backfill : generates BACKFILL_DAYS of historical data first, then continuous
# normal   : continuous generation only (no backfill)
MODE=normal

# Number of days to backfill (only used when MODE=backfill)
BACKFILL_DAYS=90

# Interval in seconds between data points during backfill
BACKFILL_INTERVAL=60

# --- Entity Configuration ---
# Total entities = NUM_NORMAL + NUM_LOWER_OUTLIER + NUM_UPPER_OUTLIER
# Normal entities generate baseline data (no anomalies)
# Lower outlier entities generate data with a negative variation (dip)
# Upper outlier entities generate data with a positive variation (spike)
NUM_NORMAL=5
NUM_LOWER_OUTLIER=1
NUM_UPPER_OUTLIER=1

# Variation percentage for outlier entities (applied as +/- to baseline)
VARIATION_PCT=75

# Prefix for entity names (entities will be named <prefix>_001, <prefix>_002, etc.)
ENTITY_PREFIX=sample

# --- Generation Settings ---
# Interval in seconds between data points in continuous mode
GENERATION_INTERVAL=60

# HEC batch size (events are batched before sending)
HEC_BATCH_SIZE=1000

# Seasonality mode: curve (sine wave peaking at noon) or stdev (Gaussian peaking at 18h)
SEASONALITY_MODE=curve

# --- Logging & Debug ---
LOG_LEVEL=INFO
DRY_RUN=false
